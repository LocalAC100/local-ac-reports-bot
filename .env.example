# =============================================================================
# Local AC Reports Bot — Environment Variables
# Copy this file to .env locally, or paste these into Render's "Environment"
# tab. Never commit the real .env to git.
# =============================================================================

# ---------- Hubstaff ----------
# Refresh token (JWT) generated at developer.hubstaff.com → Personal access tokens
HUBSTAFF_REFRESH_TOKEN=

# Organization ID (visible in any Hubstaff app URL, e.g. /organizations/595531)
HUBSTAFF_ORG_ID=595531

# ---------- GoHighLevel ----------
# Private Integration Token (starts with pit-...)
# From sub-account → Settings → Private Integrations
GHL_LOCATION_API_KEY=

# Sub-account Location ID (visible in URL: /v2/location/<LOCATION_ID>/...)
GHL_LOCATION_ID=Uy9E208xMrP6bRj5jdSK

# Webhook secret — set to any random string. Paste the same value into GHL's
# webhook config so we can verify inbound webhooks really came from GHL.
GHL_WEBHOOK_SECRET=

# ---------- Email (SMTP) ----------
# For Gmail/Workspace: smtp.gmail.com, 587, STARTTLS
# For Resend: smtp.resend.com, 587, STARTTLS, user "resend", password = API key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=admin.localac@gmail.com
SMTP_PASSWORD=
SMTP_FROM_NAME=Local AC Reports Bot
SMTP_FROM_ADDRESS=admin.localac@gmail.com

# Where reports and live alerts go
REPORT_RECIPIENT=service@local-ac.com

# ---------- Server / scheduling ----------
PORT=3000
TIMEZONE=America/New_York
NODE_ENV=production

# Live-alert lead-response threshold in minutes
LEAD_RESPONSE_THRESHOLD_MINUTES=3
